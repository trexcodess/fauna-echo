{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
     "outputs": [".next/**", "!.next/cache/**", "dist/**"],
       "env": ["NGC_API_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NGC_API_KEY"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
  
  }
}
